    "    crs=\"EPSG:4326\",\n",
    ")\n",
    "\n",
    "# Distance/contiguity-based spatial weights (K-nearest-neighbour weights on country centroids)\n",
    "w = KNN.from_dataframe(country_gdf, k=4)\n",
